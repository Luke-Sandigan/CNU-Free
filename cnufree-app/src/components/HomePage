import HomeNavBar from "../components/HomeNavBar";
import SideBar from '../components/Sidebar.jsx';
import SharedTracker from "./SharedTracker";
import Chat from "./Chat";
import Connections from "./Connections";
import { useState, useEffect } from "react";
import {
  Calendar,
  Compass,
  MessageSquare,
  Users,
  User,
  Edit
} from "lucide-react";

function HomePage({ defaultTab = 'planner' }) {
  const [isOpen, setIsOpen] = useState(false);
  const [activeTab, setActiveTab] = useState(defaultTab);
  const [profileDrawerOpen, setProfileDrawerOpen] = useState(false);

  // Sync active tab state when URL route defaultTab prop changes
  useEffect(() => {
    setActiveTab(defaultTab);
  }, [defaultTab]);

  // Student Profile details
  const [userName, setUserName] = useState(() => localStorage.getItem('cnufree_userName') || '');
  const [userCourse, setUserCourse] = useState(() => localStorage.getItem('cnufree_userCourse') || '');
  const [userId, setUserId] = useState(() => localStorage.getItem('cnufree_userId') || '');

  useEffect(() => {
    localStorage.setItem('cnufree_userName', userName);
  }, [userName]);

  useEffect(() => {
    localStorage.setItem('cnufree_userCourse', userCourse);
  }, [userCourse]);

  useEffect(() => {
    localStorage.setItem('cnufree_userId', userId);
  }, [userId]);

  // Search input state
  const [searchQuery, setSearchQuery] = useState('');

  // Toast Notification state
  const [notification, setNotification] = useState(null);

  const showNotification = (text) => {
    setNotification(text);
    setTimeout(() => {
      setNotification(null);
    }, 3000);
  };

  const handleTabChange = (tab) => {
    setActiveTab(tab);

    let path = '/Home';
    if (tab === 'planner') path = '/Planner';
    if (tab === 'tracker') path = '/SharedTracker';
    if (tab === 'chats') path = '/Chat';
    if (tab === 'connections') path = '/Connections';
    window.history.pushState({}, '', path);
  };

  // Planner State
  const [schedule, setSchedule] = useState(() => {
    const saved = localStorage.getItem('cnufree_schedule');
    return saved ? JSON.parse(saved) : [];
  });
  const [timetablePage, setTimetablePage] = useState('mon-fri'); // 'mon-fri' | 'sat-sun'
  const [courses, setCourses] = useState(() => {
    const saved = localStorage.getItem('cnufree_courses');
    return saved ? JSON.parse(saved) : [];
  });
  const [tasks, setTasks] = useState(() => {
    const saved = localStorage.getItem('cnufree_tasks');
    return saved ? JSON.parse(saved) : [];
  });

  // Folder modal states
  const [addFolderOpen, setAddFolderOpen] = useState(false);
  const [newFolderTitle, setNewFolderTitle] = useState('');
  const [newFolderColor, setNewFolderColor] = useState('purple');
  const [newFolderEmoji, setNewFolderEmoji] = useState('📁');

  useEffect(() => {
    localStorage.setItem('cnufree_schedule', JSON.stringify(schedule));
  }, [schedule]);

  useEffect(() => {
    localStorage.setItem('cnufree_courses', JSON.stringify(courses));
  }, [courses]);

  useEffect(() => {
    localStorage.setItem('cnufree_tasks', JSON.stringify(tasks));
  }, [tasks]);

  // Task form input states
  const [newTaskText, setNewTaskText] = useState('');
  const [newTaskPriority, setNewTaskPriority] = useState('Medium');

  const handleAddTaskSubmit = (e) => {
    e.preventDefault();
    if (!newTaskText.trim()) return;
    const newTask = {
      id: Date.now(),
      text: newTaskText.trim(),
      priority: newTaskPriority,
      checked: false
    };
    setTasks([...tasks, newTask]);
    setNewTaskText('');
    showNotification(`📋 Added task: "${newTask.text}"`);
  };

  const handleDeleteTask = (id, text) => {
    setTasks(tasks.filter(t => t.id !== id));
    showNotification(`🗑️ Deleted task: "${text}"`);
  };

  // Add class states
  const [addScheduleOpen, setAddScheduleOpen] = useState(false);
  const [newSubject, setNewSubject] = useState('');
  const [newDay, setNewDay] = useState('mon');
  const [newColor, setNewColor] = useState('purple');

  const [startHour, setStartHour] = useState('09');
  const [startMin, setStartMin] = useState('00');
  const [startAmpm, setStartAmpm] = useState('AM');
  const [endHour, setEndHour] = useState('10');
  const [endMin, setEndMin] = useState('30');
  const [endAmpm, setEndAmpm] = useState('AM');

  const hours = Array.from({ length: 12 }, (_, i) => String(i + 1).padStart(2, '0'));
  const minutes = Array.from({ length: 60 }, (_, i) => String(i).padStart(2, '0'));
  const ampms = ['AM', 'PM'];

  const parseTimeToMinutes = (timeStr) => {
    const match = timeStr.match(/^(\d+):(\d+)\s*(AM|PM)/i);
    if (!match) return 0;
    let h = parseInt(match[1]);
    const m = parseInt(match[2]);
    const ampm = match[3].toUpperCase();
    if (ampm === 'PM' && h < 12) h += 12;
    if (ampm === 'AM' && h === 12) h = 0;
    return h * 60 + m;
  };

  const activeDays = timetablePage === 'mon-fri'
    ? ['mon', 'tue', 'wed', 'thu', 'fri']
    : ['sat', 'sun'];

  const activeDaysHeaders = timetablePage === 'mon-fri'
    ? ['Mon', 'Tue', 'Wed', 'Thu', 'Fri']
    : ['Sat', 'Sun'];

  const getSortedTimeSlots = () => {
    const activeSchedule = schedule.filter(item => activeDays.includes(item.day));
    const slots = [...new Set(activeSchedule.map(item => item.time))];
    return slots.sort((a, b) => {
      const startA = a.split(' - ')[0];
      const startB = b.split(' - ')[0];
      return parseTimeToMinutes(startA) - parseTimeToMinutes(startB);
    });
  };

  const handleAddScheduleSubmit = (e) => {
    e.preventDefault();
    if (!newSubject.trim()) return;

    const startTimeStr = `${startHour}:${startMin} ${startAmpm}`;
    const endTimeStr = `${endHour}:${endMin} ${endAmpm}`;

    const startMinVal = parseTimeToMinutes(startTimeStr);
    const endMinVal = parseTimeToMinutes(endTimeStr);
    if (startMinVal >= endMinVal) {
      alert('Error: End time must be after start time.');
      return;
    }

    const timeString = `${startTimeStr} - ${endTimeStr}`;
    const isOverlapped = schedule.some(item =>
      item.day === newDay && item.time === timeString
    );
    if (isOverlapped) {
      alert('Error: A class is already scheduled on this day during this time period.');
      return;
    }

    const newItem = {
      id: Date.now(),
      subject: newSubject.trim().toUpperCase(),
      day: newDay,
      time: timeString,
      color: newColor
    };

    setSchedule([...schedule, newItem]);
    setNewSubject('');
    setAddScheduleOpen(false);

    if (newDay === 'sat' || newDay === 'sun') {
      setTimetablePage('sat-sun');
    } else {
      setTimetablePage('mon-fri');
    }
    showNotification(`📅 Scheduled ${newItem.subject} on ${newDay.toUpperCase()}`);
  };

  const handleRemoveSchedule = (id, subject) => {
    setSchedule(schedule.filter(item => item.id !== id));
    showNotification(`🗑️ Removed ${subject} from timetable.`);
  };

  const handleAddCourseSubmit = (e) => {
    e.preventDefault();
    if (!newFolderTitle.trim()) return;

    const newCourse = {
      title: newFolderTitle.trim(),
      color: newFolderColor,
      emoji: newFolderEmoji,
      files: 0,
      tasks: 0
    };

    setCourses([...courses, newCourse]);
    setNewFolderTitle('');
    setNewFolderColor('purple');
    setNewFolderEmoji('📁');
    setAddFolderOpen(false);
    showNotification(`📁 Added Folder: ${newCourse.title}`);
  };

  const handleDeleteCourse = (idx, title) => {
    const updated = [...courses];
    updated.splice(idx, 1);
    setCourses(updated);
    showNotification(`🗑️ Removed folder: ${title}`);
  };

  const handleTaskToggle = (id) => {
    setTasks(tasks.map(t => t.id === id ? { ...t, checked: !t.checked } : t));
  };

  const sortedScheduleTimeSlots = getSortedTimeSlots();

  // Shared Tracker
  const [peers, setPeers] = useState(() => {
    const saved = localStorage.getItem('cnufree_peers');
    return saved ? JSON.parse(saved) : [];
  });

  useEffect(() => {
    localStorage.setItem('cnufree_peers', JSON.stringify(peers));
  }, [peers]);

  const handlePeerToggle = (peerId) => {
    setPeers(peers.map(p => p.id === peerId ? { ...p, active: !p.active } : p));
  };

  // Edit profile handler
  const handleEditProfile = () => {
    const newName = prompt('Enter Student Name:', userName);
    if (!newName) return;
    const newCourse = prompt('Enter Course/Major:', userCourse);
    if (!newCourse) return;
    const newId = prompt('Enter Student ID No:', userId);
    if (!newId) return;

    setUserName(newName);
    setUserCourse(newCourse);
    setUserId(newId);
    showNotification('👤 Student profile updated successfully.');
  };

  return (
    <div className="flex flex-col w-full min-h-screen bg-[#F9FAFB]">
      <SideBar
        open={isOpen}
        close={() => setIsOpen(false)}
        activeTab={activeTab}
        onTabChange={handleTabChange}
        onTriggerProfile={() => setProfileDrawerOpen(true)}
        userName={userName}
        userCourse={userCourse}
      />
      <HomeNavBar
        isOpen={isOpen}
        setIsOpen={setIsOpen}
        searchQuery={searchQuery}
        onSearchChange={setSearchQuery}
        onTriggerProfile={() => setProfileDrawerOpen(true)}
        userName={userName}
      />

      {/* Main Workspace Frame */}
      <main className="flex-1 max-w-7xl mx-auto w-full p-4 md:p-8">

        {/* PERSONAL PLANNER            */}
        {activeTab === 'planner' && (
          <section className="animate-fadeIn">
            <div className="flex flex-wrap gap-4 justify-between items-start mb-6">
              <div>
                <h2 className="text-xl md:text-2xl font-black text-gray-900 tracking-tight">My Academic Planner</h2>
                <p className="text-sm text-gray-500 font-medium">Your personal schedule, active tasks, and course folders.</p>
              </div>
              <div className="flex gap-3">
                <button className="bg-[#111827] text-white py-2 px-4 rounded-lg font-bold text-xs hover:bg-black transition shadow-sm" onClick={() => setAddScheduleOpen(true)}>
                  + Add Class
                </button>
                <button className="bg-white border border-gray-300 text-gray-700 py-2 px-4 rounded-lg font-bold text-xs hover:bg-gray-50 transition" onClick={() => showNotification('🔄 Synced schedules with local calendar!')}>
                  🔄 Sync Calendar
                </button>
              </div>
            </div>

            {/* Weekly Timetable Table */}
            <div className="bg-white border border-[#E2E8F0] rounded-2xl p-6 mb-8 shadow-sm">
              <div className="flex flex-wrap gap-4 items-center justify-between mb-6">
                <div className="flex items-center gap-2 font-extrabold text-[15px] text-[#111827]">
                  📅 Weekly Timetable
                </div>

                <div className="flex bg-[#F4F6F9] p-1 border border-slate-200 rounded-xl">
                  <button
                    onClick={() => setTimetablePage('mon-fri')}
                    className={`py-1.5 px-3 rounded-lg text-[11px] font-extrabold transition ${timetablePage === 'mon-fri' ? 'bg-[#111827] text-white shadow-sm' : 'text-gray-500 hover:text-[#111827]'
                      }`}
                  >
                    Mon - Fri
                  </button>
                  <button
                    onClick={() => setTimetablePage('sat-sun')}
                    className={`py-1.5 px-3 rounded-lg text-[11px] font-extrabold transition ${timetablePage === 'sat-sun' ? 'bg-[#111827] text-white shadow-sm' : 'text-gray-500 hover:text-[#111827]'
                      }`}
                  >
                    Sat - Sun
                  </button>
                </div>
              </div>

              {/* Schedule Grid Wrapper */}
              <div className="overflow-x-auto border border-gray-100 rounded-xl">
                <div className="min-w-[700px]">

                  {/* Headers */}
                  <div
                    className="grid bg-[#F9FAFB] border-b border-gray-100"
                    style={{ gridTemplateColumns: `repeat(${activeDays.length}, 1fr)` }}
                  >
                    {activeDaysHeaders.map((dayHeader) => (
                      <div key={dayHeader} className="py-3 px-4 text-[11px] font-extrabold text-gray-400 text-center uppercase tracking-wider border-r last:border-r-0 border-gray-100">
                        {dayHeader}
                      </div>
                    ))}
                  </div>

                  {/* Body */}
                  <div className="divide-y divide-gray-100 bg-white">
                    {sortedScheduleTimeSlots.length === 0 ? (
                      <div className="py-12 text-center text-sm font-semibold text-gray-400 bg-white">
                        No classes scheduled. Click "+ Add Class" to enter details!
                      </div>
                    ) : (
                      sortedScheduleTimeSlots.map((timePeriod, rowIndex) => (
                        <div
                          key={rowIndex}
                          className="grid divide-x divide-gray-100"
                          style={{ gridTemplateColumns: `repeat(${activeDays.length}, 1fr)` }}
                        >
                          {activeDays.map(day => {
                            const match = schedule.find(item => item.day === day && item.time === timePeriod);

                            let accentColor = '#8B5CF6';
                            let bgGlow = 'rgba(139, 92, 246, 0.05)';
                            if (match) {
                              if (match.color === 'orange') {
                                accentColor = '#F97316';
                                bgGlow = 'rgba(249, 115, 22, 0.05)';
                              } else if (match.color === 'green') {
                                accentColor = '#10B981';
                                bgGlow = 'rgba(16, 185, 129, 0.05)';
                              }
                            }

                            return (
                              <div key={day} className="p-2.5 h-[80px] flex items-center justify-center relative">
                                {match ? (
                                  <div
                                    className="w-full h-full flex flex-col justify-center items-center rounded-lg p-2 relative border-l-4 transition hover:shadow-sm"
                                    style={{ borderLeftColor: accentColor, backgroundColor: bgGlow }}
                                  >
                                    <button
                                      onClick={() => handleRemoveSchedule(match.id, match.subject)}
                                      className="absolute top-1.5 right-2 text-[8px] font-extrabold text-gray-400 hover:text-red-500 transition"
                                      title="Delete"
                                    >
                                      ✕
                                    </button>
                                    <div className="font-extrabold text-xs text-gray-900 tracking-tight">{match.subject}</div>
                                    <div className="text-[9px] text-gray-400 mt-1 font-semibold">{match.time.replace(/AM|PM/g, '')}</div>
                                  </div>
                                ) : null}
                              </div>
                            );
                          })}
                        </div>
                      ))
                    )}
                  </div>
                </div>
              </div>
            </div>

            {/* Bottom folders and checklist */}
            <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">

              {/* Folder List */}
              <div className="lg:col-span-2">
                <div className="flex justify-between items-center mb-4">
                  <h3 className="font-extrabold text-[15px] text-[#111827]">📁 Set Courses / Folders</h3>
                  <button className="bg-white border border-gray-300 text-gray-700 py-1.5 px-3 rounded-lg font-bold text-xs hover:bg-gray-50 transition" onClick={() => setAddFolderOpen(true)}>
                    + Add Folder
                  </button>
                </div>

                <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
                  {courses.length === 0 ? (
                    <div className="w-full flex flex-col items-start self-stretch rounded-2xl border border-[#E2E8F0] bg-[#F4F6F9] p-8 gap-3 col-span-full">
                      <div className="text-[14px] font-extrabold text-[#111827]">No Folders added yet.</div>
                      <p className="text-[12px] text-gray-500 font-medium">Create folders to organize your class notes, files, and tasks.</p>
                      <button className="bg-[#111827] text-white hover:bg-black py-2 px-4 rounded-lg font-bold text-xs transition" onClick={() => setAddFolderOpen(true)}>
                        + Add Folder
                      </button>
                    </div>
                  ) : (
                    courses.map((course, idx) => (
                      <div
                        className={`flex flex-col items-start self-stretch rounded-2xl border border-[#E2E8F0] bg-[#F4F6F9] p-6 relative overflow-hidden transition hover:-translate-y-1 hover:shadow-sm cursor-pointer border-l-4 ${course.color === 'purple' ? 'border-l-indigo-600' :
                          course.color === 'orange' ? 'border-l-orange-500' : 'border-l-emerald-500'
                          }`}
                        key={idx}
                      >
                        <div className="flex justify-between items-center w-full mb-4">
                          <span className={`w-12 h-3 rounded-t ${course.color === 'purple' ? 'bg-indigo-600' :
                            course.color === 'orange' ? 'bg-orange-500' : 'bg-emerald-500'
                            }`}></span>
                          <button onClick={() => handleDeleteCourse(idx, course.title)} className="text-gray-400 hover:text-red-500 transition-colors">
                            ✕
                          </button>
                        </div>
                        <div className="text-2xl mb-2">{course.emoji}</div>
                        <h4 className="font-extrabold text-[14px] text-gray-900 mb-1">{course.title}</h4>
                        <p className="text-[11px] text-gray-500">{course.files} files • {course.tasks} tasks pending</p>
                      </div>
                    ))
                  )}
                </div>
              </div>

              {/* Tasks List */}
              <div className="bg-white border border-[#E2E8F0] rounded-2xl p-6 shadow-sm self-start">
                <h3 className="font-extrabold text-[15px] text-[#111827] mb-4">📋 Tasks & Deadlines</h3>

                {/* Task Input Form */}
                <form onSubmit={handleAddTaskSubmit} className="mb-5 flex flex-col gap-2.5">
                  <input
                    type="text"
                    placeholder="New task text..."
                    value={newTaskText}
                    onChange={(e) => setNewTaskText(e.target.value)}
                    required
                    className="border border-slate-200 rounded-lg p-2.5 text-xs font-semibold focus:outline-none focus:ring-1 focus:ring-[#111827] w-full"
                  />
                  <div className="flex gap-2 justify-between items-center">
                    <select
                      value={newTaskPriority}
                      onChange={(e) => setNewTaskPriority(e.target.value)}
                      className="border border-slate-200 rounded-lg p-2 text-xs font-semibold focus:outline-none bg-white text-gray-700"
                    >
                      <option value="High">High</option>
                      <option value="Medium">Medium</option>
                      <option value="Low">Low</option>
                    </select>
                    <button type="submit" className="bg-[#111827] text-white hover:bg-black py-2 px-3 rounded-lg font-bold text-xs transition">
                      + Add Task
                    </button>
                  </div>
                </form>

                <div className="flex flex-col gap-3">
                  {tasks.length === 0 ? (
                    <div className="text-center py-8 text-gray-400 font-semibold text-xs border border-dashed border-slate-200 rounded-xl">
                      No tasks added yet. Add tasks above to track deadlines!
                    </div>
                  ) : (
                    tasks.map(task => (
                      <div className="flex flex-col items-start self-stretch rounded-2xl border border-[#E2E8F0] bg-[#F4F6F9] p-4 gap-2.5 transition-all w-full" key={task.id}>
                        <div className="flex items-center gap-3 w-full">
                          <input
                            type="checkbox"
                            id={`task-chk-${task.id}`}
                            className="w-[18px] h-[18px] accent-[#111827] cursor-pointer"
                            checked={task.checked}
                            onChange={() => handleTaskToggle(task.id)}
                          />
                          <label
                            htmlFor={`task-chk-${task.id}`}
                            className={`flex-1 text-[13px] cursor-pointer select-none truncate ${task.checked ? 'line-through text-gray-400' : 'font-bold text-[#111827]'}`}
                          >
                            {task.text}
                          </label>
                          <button
                            type="button"
                            onClick={() => handleDeleteTask(task.id, task.text)}
                            className="text-gray-400 hover:text-red-500 font-extrabold text-[10px] p-0.5"
                            title="Delete Task"
                          >
                            ✕
                          </button>
                        </div>
                        <span className={`text-[10px] font-bold px-2.5 py-0.5 rounded-full ${task.priority.toLowerCase() === 'high' ? 'bg-red-50 text-red-600' :
                          task.priority.toLowerCase() === 'medium' ? 'bg-amber-50 text-amber-600' : 'bg-gray-100 text-gray-600'
                          }`}>
                          {task.priority} Priority
                        </span>
                      </div>
                    ))
                  )}
                </div>
              </div>

            </div>
          </section>
        )}

        {/* Dynamic sub-page routes */}
        {activeTab === 'tracker' && (
          <SharedTracker
            peers={peers}
            onPeerToggle={handlePeerToggle}
            showNotification={showNotification}
            onNavigateToChats={() => handleTabChange('chats')}
          />
        )}

        {activeTab === 'chats' && (
          <Chat
            showNotification={showNotification}
            peers={peers}
          />
        )}

        {activeTab === 'connections' && (
          <Connections
            peers={peers}
            setPeers={setPeers}
            showNotification={showNotification}
          />
        )}

      </main>

      {/* ADD SCHEDULE MODAL OVERLAY (PLANNER)       */}
      {addScheduleOpen && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4 backdrop-blur-xs">
          <div className="bg-white rounded-2xl border border-slate-200 max-w-[460px] w-full p-6 shadow-xl animate-scaleIn">
            <div className="flex justify-between items-center mb-5 border-b border-gray-100 pb-3">
              <h3 className="font-extrabold text-sm text-[#111827]">Add Timetable Class</h3>
              <button className="text-gray-400 hover:text-gray-600 transition p-1" onClick={() => setAddScheduleOpen(false)}>✕</button>
            </div>

            <form onSubmit={handleAddScheduleSubmit} className="flex flex-col gap-4">
              <div>
                <label className="block text-[10px] font-black text-gray-400 uppercase tracking-wider mb-1">Subject Name / Code</label>
                <input
                  type="text"
                  placeholder="e.g. ABCD123"
                  required
                  value={newSubject}
                  onChange={(e) => setNewSubject(e.target.value)}
                  className="w-full border border-slate-200 rounded-lg p-2.5 text-xs font-semibold focus:outline-none focus:ring-1 focus:ring-[#111827] focus:border-[#111827]"
                />
              </div>

              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-[10px] font-black text-gray-400 uppercase tracking-wider mb-1">Day of Week</label>
                  <select
                    value={newDay}
                    onChange={(e) => setNewDay(e.target.value)}
                    className="w-full border border-slate-200 rounded-lg p-2.5 text-xs font-semibold focus:outline-none focus:ring-1 focus:ring-[#111827]"
                  >
                    <option value="mon">Monday</option>
                    <option value="tue">Tuesday</option>
                    <option value="wed">Wednesday</option>
                    <option value="thu">Thursday</option>
                    <option value="fri">Friday</option>
                    <option value="sat">Saturday</option>
                    <option value="sun">Sunday</option>
                  </select>
                </div>

                <div>
                  <label className="block text-[10px] font-black text-gray-400 uppercase tracking-wider mb-1">Color Theme</label>
                  <select
                    value={newColor}
                    onChange={(e) => setNewColor(e.target.value)}
                    className="w-full border border-slate-200 rounded-lg p-2.5 text-xs font-semibold focus:outline-none focus:ring-1 focus:ring-[#111827]"
                  >
                    <option value="purple">Lavender (Purple)</option>
                    <option value="orange">Peach (Orange)</option>
                    <option value="green">Mint (Green)</option>
                  </select>
                </div>
              </div>

              <div>
                <label className="block text-[10px] font-black text-gray-400 uppercase tracking-wider mb-2">Class Time Period</label>
                <div className="grid grid-cols-2 gap-4">
                  
                  {/* Start time picker */}
                  <div>
                    <span className="block text-[9px] font-extrabold text-gray-400 mb-1.5">START: <strong className="text-[#111827]">{startHour}:{startMin} {startAmpm}</strong></span>
                    <div className="flex gap-1 border border-slate-200 rounded-lg p-1.5 bg-slate-50 h-32">
                      {/* Hour scroll */}
                      <div className="flex-1 overflow-y-auto h-full flex flex-col gap-0.5 pr-0.5 custom-scrollbar">
                        {hours.map(h => (
                          <div 
                            key={`sh-${h}`}
                            onClick={() => setStartHour(h)}
                            className={`py-1 text-[10px] font-black text-center rounded-md cursor-pointer transition ${
                              startHour === h ? 'bg-[#111827] text-white' : 'text-gray-700 hover:bg-slate-200'
                            }`}
                          >
                            {h}
                          </div>
                        ))}
                      </div>
                      
                      {/* Minute scroll */}
                      <div className="flex-1 overflow-y-auto h-full flex flex-col gap-0.5 pr-0.5 custom-scrollbar">
                        {minutes.map(m => (
                          <div 
                            key={`sm-${m}`}
                            onClick={() => setStartMin(m)}
                            className={`py-1 text-[10px] font-black text-center rounded-md cursor-pointer transition ${
                              startMin === m ? 'bg-[#111827] text-white' : 'text-gray-700 hover:bg-slate-200'
                            }`}
                          >
                            {m}
                          </div>
                        ))}
                      </div>

                      {/* AM/PM selection */}
                      <div className="w-9 flex flex-col gap-1 justify-center">
                        {ampms.map(a => (
                          <div 
                            key={`sa-${a}`}
                            onClick={() => setStartAmpm(a)}
                            className={`py-1.5 text-[10px] font-black text-center rounded-md cursor-pointer transition ${
                              startAmpm === a ? 'bg-[#111827] text-white' : 'text-gray-700 hover:bg-slate-200'
                            }`}
                          >
                            {a}
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>

                  {/* End time picker */}
                  <div>
                    <span className="block text-[9px] font-extrabold text-gray-400 mb-1.5">END: <strong className="text-[#111827]">{endHour}:{endMin} {endAmpm}</strong></span>
                    <div className="flex gap-1 border border-slate-200 rounded-lg p-1.5 bg-slate-50 h-32">
                      {/* Hour scroll */}
                      <div className="flex-1 overflow-y-auto h-full flex flex-col gap-0.5 pr-0.5 custom-scrollbar">
                        {hours.map(h => (
                          <div 
                            key={`eh-${h}`}
                            onClick={() => setEndHour(h)}
                            className={`py-1 text-[10px] font-black text-center rounded-md cursor-pointer transition ${
                              endHour === h ? 'bg-[#111827] text-white' : 'text-gray-700 hover:bg-slate-200'
                            }`}
                          >
                            {h}
                          </div>
                        ))}
                      </div>
                      
                      {/* Minute scroll */}
                      <div className="flex-1 overflow-y-auto h-full flex flex-col gap-0.5 pr-0.5 custom-scrollbar">
                        {minutes.map(m => (
                          <div 
                            key={`em-${m}`}
                            onClick={() => setEndMin(m)}
                            className={`py-1 text-[10px] font-black text-center rounded-md cursor-pointer transition ${
                              endMin === m ? 'bg-[#111827] text-white' : 'text-gray-700 hover:bg-slate-200'
                            }`}
                          >
                            {m}
                          </div>
                        ))}
                      </div>

                      {/* AM/PM selection */}
                      <div className="w-9 flex flex-col gap-1 justify-center">
                        {ampms.map(a => (
                          <div 
                            key={`ea-${a}`}
                            onClick={() => setEndAmpm(a)}
                            className={`py-1.5 text-[10px] font-black text-center rounded-md cursor-pointer transition ${
                              endAmpm === a ? 'bg-[#111827] text-white' : 'text-gray-700 hover:bg-slate-200'
                            }`}
                          >
                            {a}
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>

                </div>
              </div>

            </form>
          </div>
        </div>
      )}

      {/* ADD FOLDER MODAL OVERLAY */}
      {addFolderOpen && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4 backdrop-blur-xs animate-fadeIn">
          <div className="bg-white rounded-2xl border border-slate-200 max-w-[420px] w-full p-6 shadow-xl animate-scaleIn">
            <div className="flex justify-between items-center mb-5 border-b border-gray-100 pb-3">
              <h3 className="font-extrabold text-sm text-[#111827]">Create Course Folder</h3>
              <button className="text-gray-400 hover:text-gray-600 transition p-1" onClick={() => setAddFolderOpen(false)}>✕</button>
            </div>
            
            <form onSubmit={handleAddCourseSubmit} className="flex flex-col gap-4">
              <div>
                <label className="block text-[10px] font-black text-gray-400 uppercase tracking-wider mb-1">Folder Name / Code</label>
                <input 
                  type="text" 
                  placeholder="e.g. ITMC212 - OOP" 
                  required 
                  value={newFolderTitle}
                  onChange={(e) => setNewFolderTitle(e.target.value)}
                  className="w-full border border-slate-200 rounded-lg p-2.5 text-xs font-semibold focus:outline-none focus:ring-1 focus:ring-[#111827]"
                />
              </div>

              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-[10px] font-black text-gray-400 uppercase tracking-wider mb-1">Color Theme</label>
                  <select 
                    value={newFolderColor} 
                    onChange={(e) => setNewFolderColor(e.target.value)}
                    className="w-full border border-slate-200 rounded-lg p-2.5 text-xs font-semibold focus:outline-none focus:ring-1 focus:ring-[#111827] bg-white text-gray-700"
                  >
                    <option value="purple">Indigo (Purple)</option>
                    <option value="orange">Peach (Orange)</option>
                    <option value="green">Mint (Green)</option>
                  </select>
                </div>

                <div>
                  <label className="block text-[10px] font-black text-gray-400 uppercase tracking-wider mb-1">Emoji Icon</label>
                  <select 
                    value={newFolderEmoji} 
                    onChange={(e) => setNewFolderEmoji(e.target.value)}
                    className="w-full border border-slate-200 rounded-lg p-2.5 text-xs font-semibold focus:outline-none focus:ring-1 focus:ring-[#111827] bg-white text-gray-700"
                  >
                    <option value="📁">📁 Default Folder</option>
                    <option value="💻">💻 Computer</option>
                    <option value="🗄️">🗄️ Cabinet</option>
                    <option value="⚛️">⚛️ Science</option>
                    <option value="📚">📚 Books</option>
                    <option value="🎨">🎨 Art</option>
                  </select>
                </div>
              </div>

              <div className="flex gap-3 justify-end mt-2">
                <button type="button" className="bg-white border border-gray-300 text-gray-700 py-2 px-4 rounded-lg font-bold text-xs hover:bg-gray-50 transition" onClick={() => setAddFolderOpen(false)}>Cancel</button>
                <button type="submit" className="bg-[#111827] text-white hover:bg-black py-2 px-4 rounded-lg font-bold text-xs transition">Create Folder</button>
              </div>
            </form>
          </div>
        </div>
      )}

      {/* Profile ID Drawer overlay */}
      {profileDrawerOpen && (
        <div className="fixed inset-0 bg-black/60 z-50 flex justify-end backdrop-blur-xs" onClick={(e) => e.target.id === 'profile-drawer' && setProfileDrawerOpen(false)} id="profile-drawer">
          <div className="bg-white max-w-[420px] w-full min-h-screen p-6 flex flex-col justify-between shadow-2xl border-l border-slate-200 animate-slideLeft">

            <div>
              <div className="flex justify-between items-center mb-6">
                <h3 className="font-extrabold text-md text-[#111827]">Student ID Profile</h3>
                <button className="text-gray-400 hover:text-gray-600 text-lg transition p-1" onClick={() => setProfileDrawerOpen(false)}>✕</button>
              </div>

              {/* Plastic Student ID Card mockup */}
              <div className="bg-white border-2 border-gray-900 rounded-2xl p-6 relative shadow-md mb-8">
                <div className="flex justify-between items-center mb-6">
                  <div className="border-2 border-gray-900 py-0.5 px-2.5 rounded font-black text-xs text-gray-900">
                    ADNU
                  </div>
                  <span className="text-[9px] font-black uppercase text-gray-400 tracking-wider">Student ID Card</span>
                </div>

                <div className="flex gap-4 mb-6">
                  <div className="w-[64px] h-[64px] bg-slate-100 rounded-xl border border-gray-900 font-black text-lg flex items-center justify-center text-gray-700">
                    {userName ? userName.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase() : 'ST'}
                  </div>
                  <div className="overflow-hidden">
                    <h4 className="font-black text-sm text-gray-900 truncate">{userName || 'Student Name'}</h4>
                    <p className="text-[11px] text-gray-400 font-semibold mb-2 truncate">{userCourse || 'Major / Course'}</p>
                    <div className="text-[10px] font-bold text-gray-700 flex gap-2">
                      <span className="text-gray-400">ID No:</span> {userId || 'N/A'}
                    </div>
                    <div className="text-[10px] font-bold text-gray-700 flex gap-2">
                      <span className="text-gray-400">Year:</span> 2nd Year
                    </div>
                  </div>
                </div>

                <div className="border-t border-dashed border-gray-300 pt-4 flex flex-col items-center">
                  <div className="font-mono text-lg font-bold tracking-widest text-gray-900 select-none">
                    |||| | ||| || ||| | |||| | ||
                  </div>
                  <div className="text-[9px] text-gray-400 font-bold mt-1 tracking-wider uppercase">
                    {userId ? userId.replace(/[^0-9]/g, '') : '202510492'}
                  </div>
                </div>
              </div>

              {/* Profile controls */}
              <div className="flex flex-col gap-4">
                <h4 className="text-[10px] font-black text-gray-400 uppercase tracking-widest block border-b border-gray-100 pb-2">Profile Options</h4>
                <button
                  className="bg-[#111827] text-white hover:bg-black py-2.5 px-4 rounded-xl font-bold text-xs transition w-full flex items-center justify-center gap-2"
                  onClick={handleEditProfile}
                >
                  <Edit size={14} /> Edit Profile Data
                </button>

                <h4 className="text-[10px] font-black text-gray-400 uppercase tracking-widest block border-b border-gray-100 pb-2 mt-4">Sync Prefs</h4>
                <div className="flex items-center gap-2 text-xs font-bold text-gray-700 bg-emerald-50 border border-emerald-100 rounded-xl p-3">
                  <span className="w-2 h-2 rounded-full bg-emerald-500"></span>
                  Synced with Google Calendar
                </div>
              </div>
            </div>

            <button className="bg-gray-100 hover:bg-gray-200 text-gray-700 py-3 px-4 rounded-xl font-bold text-xs transition w-full mt-6 border border-gray-200" onClick={() => showNotification('🔄 Sync preferences updated!')}>
              Modify Sync Credentials
            </button>

          </div>
        </div>
      )}

      {notification && (
        <div
          className="fixed bottom-6 right-6 bg-white border-2 border-gray-900 text-gray-900 py-4 px-6 rounded-xl shadow-lg font-bold text-xs z-[9999] animate-slideUp"
        >
          {notification}
        </div>
      )}

      {/* Profile Onboarding Setup Modal Overlay */}
      {(!userName || !userCourse || !userId) && (
        <div className="fixed inset-0 bg-[#0F172A] z-[9999] flex items-center justify-center p-4 overflow-y-auto">
          <div className="bg-white rounded-3xl border border-slate-100 max-w-[460px] w-full p-8 shadow-2xl animate-scaleIn flex flex-col items-center">

            {/* Logo or Brand */}
            <div className="bg-[#111827] text-white py-2 px-4 rounded-xl font-black text-md tracking-wider mb-6">
              CNU Free
            </div>

            <h2 className="text-xl font-black text-gray-900 tracking-tight text-center mb-2">Set Up Your Student Profile</h2>
            <p className="text-xs text-gray-500 font-semibold text-center mb-6 leading-relaxed">
              Welcome to CNU Free! Please enter your university details to initialize your Academic Workspace and Student ID card.
            </p>

            <form
              onSubmit={(e) => {
                e.preventDefault();
                const name = e.target.name.value.trim();
                const course = e.target.course.value.trim();
                const idNum = e.target.idNum.value.trim();
                if (name && course && idNum) {
                  setUserName(name);
                  setUserCourse(course);
                  setUserId(idNum);
                  showNotification('👤 Student profile set up successfully!');
                }
              }}
              className="flex flex-col gap-4 w-full"
            >
              <div>
                <label className="block text-[10px] font-black text-gray-400 uppercase tracking-wider mb-1">Full Student Name</label>
                <input
                  type="text"
                  name="name"
                  placeholder="e.g. Juan Dela Cruz"
                  required
                  className="w-full border border-slate-200 rounded-xl p-3 text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-[#111827] focus:border-[#111827]"
                />
              </div>

              <div>
                <label className="block text-[10px] font-black text-gray-400 uppercase tracking-wider mb-1">Course / Major</label>
                <input
                  type="text"
                  name="course"
                  placeholder="e.g. BS Information Technology"
                  required
                  className="w-full border border-slate-200 rounded-xl p-3 text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-[#111827] focus:border-[#111827]"
                />
              </div>

              <div>
                <label className="block text-[10px] font-black text-gray-400 uppercase tracking-wider mb-1">Student ID Number</label>
                <input
                  type="text"
                  name="idNum"
                  placeholder="e.g. 2025-10492"
                  required
                  className="w-full border border-slate-200 rounded-xl p-3 text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-[#111827] focus:border-[#111827]"
                />
              </div>

              <button
                type="submit"
                className="bg-[#111827] text-white hover:bg-black py-3 px-4 rounded-xl font-bold text-xs mt-2 transition w-full shadow-lg"
              >
                Save and Initialize Workspace
              </button>
            </form>
          </div>
        </div>
      )}

    </div>
  );
}

export default HomePage;